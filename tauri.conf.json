{
  "productName": "AWS_Desktop_Center",
  "version": "0.1.0",
  "identifier": "com.awsdesktopcenter.rust",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "AWS Desktop Center",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/icon.png"]
  }
}
